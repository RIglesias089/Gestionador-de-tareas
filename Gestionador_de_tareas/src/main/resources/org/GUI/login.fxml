<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.canvas.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.GUI.LoginController"
           stylesheets="@../../css/login.css"
           prefWidth="1280" prefHeight="720"
           styleClass="fondo-naranja">

    <Canvas fx:id="canvasTriangulos" width="1280" height="720"
            StackPane.alignment="TOP_LEFT"/>

    <HBox prefWidth="1280" prefHeight="720" alignment="CENTER_RIGHT">

        <Pane HBox.hgrow="ALWAYS"/>

        <VBox alignment="CENTER" prefWidth="550" minWidth="550" maxWidth="550" styleClass="columna-derecha">

            <VBox alignment="TOP_CENTER" spacing="25" styleClass="card-formulario">

                <VBox alignment="CENTER" styleClass="logo-area" spacing="10">
                    <HBox alignment="CENTER" spacing="15">
                        <Canvas fx:id="canvasCheck" width="65" height="65"/>
                        <VBox alignment="CENTER_LEFT">
                            <Label text="SnowList" styleClass="titulo-principal"/>
                            <Label text="Tu organización" styleClass="titulo-secundario"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox alignment="CENTER" spacing="20" styleClass="formulario-area">

                    <VBox spacing="5" alignment="CENTER_LEFT">
                        <Label text="Correo electrónico" styleClass="label-input"/>
                        <TextField fx:id="campoCorreo"
                                   promptText="Ingresa tu correo"
                                   styleClass="campo-texto"/>
                    </VBox>

                    <VBox spacing="5" alignment="CENTER_LEFT">
                        <Label text="Contraseña" styleClass="label-input"/>
                        <PasswordField fx:id="campoContrasena"
                                       promptText="Ingresa tu contraseña"
                                       styleClass="campo-texto"/>
                    </VBox>

                    <Button text="Iniciar sesión"
                            onAction="#handleLogin"
                            styleClass="boton-iniciar"
                            maxWidth="Infinity"/>

                    <VBox alignment="CENTER" spacing="8" styleClass="links-contenedor">
                        <HBox alignment="CENTER" spacing="4">
                            <Label text="¿Olvidaste tu contraseña? Ve a " styleClass="subtexto"/>
                            <Label text="Recuperar contraseña"
                                   styleClass="subtexto link-texto"
                                   onMouseClicked="#handleRecuperar"/>
                        </HBox>
                        <HBox alignment="CENTER" spacing="4">
                            <Label text="No tienes una cuenta. Ve a " styleClass="subtexto"/>
                            <Label text="crear cuenta"
                                   styleClass="subtexto link-texto"
                                   onMouseClicked="#handleCrearCuenta"/>
                        </HBox>
                    </VBox>
                </VBox>
            </VBox>
        </VBox>
    </HBox>
</StackPane>